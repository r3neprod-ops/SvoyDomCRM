DATABASE_URL=postgres://user:password@host/database?sslmode=require
JWT_SECRET=replace-with-long-random-secret

# Comma-separated landing origins that may POST leads to /api/lead.
ALLOWED_LEAD_ORIGIN=https://svoydom-lugansk.ru

# Optional integrations.
BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/your-webhook-token
VAPID_PUBLIC_KEY=
# Optional alias for hosts that expose public env vars only with NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:r3neprod@gmail.com

# S3-compatible storage for CRM chat photos and video notes.
S3_ENDPOINT=https://s3.example.com
S3_REGION=ru-1
S3_BUCKET=svoydom-crm
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=https://cdn.example.com/svoydom-crm
